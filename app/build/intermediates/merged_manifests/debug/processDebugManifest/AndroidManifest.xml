<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.eventsystem"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="23"
        android:targetSdkVersion="35" />

    <application
        android:allowBackup="true"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:label="Event System"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/AppTheme" >
        <activity
            android:name="com.example.eventsystem.UserProfileActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name="com.example.eventsystem.EditEventActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name="com.example.eventsystem.EventDetailsActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name="com.example.eventsystem.MainActivity"
            android:exported="true"
            android:screenOrientation="fullSensor" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>